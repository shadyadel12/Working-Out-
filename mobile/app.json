{
  "expo": {
    "name": "Trainova",
    "slug": "bloodyx",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "scheme": "trainova",
    "platforms": ["ios", "android"],
    "newArchEnabled": false,
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trainova.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Trainova uses the camera only when you choose to capture workout evidence, assignment photos, progress photos, or chat media.",
        "NSPhotoLibraryUsageDescription": "Trainova accesses selected photos and videos only when you attach workout evidence, assignment photos, progress photos, or chat media.",
        "NSMicrophoneUsageDescription": "Trainova uses the microphone only when you choose to record a voice message for your coach or player."
      },
      "privacyManifests": {
        "NSPrivacyTracking": false,
        "NSPrivacyTrackingDomains": [],
        "NSPrivacyAccessedAPITypes": [
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryUserDefaults", "NSPrivacyAccessedAPITypeReasons": ["CA92.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryFileTimestamp", "NSPrivacyAccessedAPITypeReasons": ["C617.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategorySystemBootTime", "NSPrivacyAccessedAPITypeReasons": ["35F9.1"] },
          { "NSPrivacyAccessedAPIType": "NSPrivacyAccessedAPICategoryDiskSpace", "NSPrivacyAccessedAPITypeReasons": ["E174.1"] }
        ]
      }
    },
    "android": {
      "package": "com.trainova.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#111113"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#050914",
          "image": "./assets/splash.png",
          "imageWidth": 260,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Trainova to use the microphone when you choose to record a coach or player voice message."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trainova to select workout evidence, assignment photos, progress photos, or chat media.",
          "cameraPermission": "Allow Trainova to capture workout evidence, assignment photos, progress photos, or chat media."
        }
      ],
      "expo-document-picker",
      "expo-asset",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a1bd66e9-592e-4477-a82e-d5c77e436d69"
      }
    },
    "owner": "adelshadys-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a1bd66e9-592e-4477-a82e-d5c77e436d69"
    }
  }
}
