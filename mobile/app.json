{
  "expo": {
    "name": "Trainova",
    "slug": "bloodyx",
    "version": "0.1.0",
    "platforms": ["ios", "android"],
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coachplatform.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.coachplatform.app",
      "adaptiveIcon": {
        "backgroundColor": "#111113"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Trainova to record voice messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Trainova to attach workout and chat media.",
          "cameraPermission": "Allow Trainova to take workout and chat photos."
        }
      ],
      "expo-document-picker",
      "expo-asset",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a1bd66e9-592e-4477-a82e-d5c77e436d69"
      }
    },
    "owner": "adelshadys-team",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a1bd66e9-592e-4477-a82e-d5c77e436d69"
    }
  }
}
