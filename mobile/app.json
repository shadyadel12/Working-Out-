{
  "expo": {
    "name": "Coach Platform",
    "slug": "bloodyx",
    "version": "0.1.0",
    "newArchEnabled": false,
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.coachplatform.app"
    },
    "android": {
      "package": "com.coachplatform.app",
      "adaptiveIcon": {
        "backgroundColor": "#111113"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Coach Platform to record voice messages."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Coach Platform to attach workout and chat media.",
          "cameraPermission": "Allow Coach Platform to take workout and chat photos."
        }
      ],
      "expo-document-picker",
      "expo-asset",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "a1bd66e9-592e-4477-a82e-d5c77e436d69"
      }
    },
    "owner": "adelshadys-team"
  }
}
